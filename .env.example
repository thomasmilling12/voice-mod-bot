# ── Required ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here

# ── Channels (optional) ───────────────────────────────────
# Text channel ID where the bot posts private "Recording started/stopped" messages (staff only)
LOG_CHANNEL_ID=

# Text channel ID where completed audio files are uploaded for download/playback
RECORDING_CHANNEL_ID=1496001557290946591

# Text channel ID where the bot posts a public "Recording has started" notice (visible to all members)
ANNOUNCE_CHANNEL_ID=

# Text channel ID where crash/disconnect alerts are posted
ALERT_CHANNEL_ID=

# Text channel ID where watchdog heartbeat messages are posted (defaults to LOG_CHANNEL_ID)
HEARTBEAT_CHANNEL_ID=

# Max audio file upload size in MB. Keep at 24 unless your server has a boost-tier raising the limit.
DISCORD_UPLOAD_LIMIT_MB=24

# ── Permissions ───────────────────────────────────────────
# Comma-separated Discord user IDs always allowed to control the bot (regardless of roles)
ADMIN_USER_IDS=

# Comma-separated Discord role IDs allowed to control the bot
ADMIN_ROLE_IDS=850391095845584937,850391378559238235,990011447193006101,1055823929358430248

# ── Auto-join ─────────────────────────────────────────────
# Set true to enable auto-join when enough members enter a voice channel
AUTO_JOIN_ENABLED=false

# Minimum number of humans in a voice channel before auto-join triggers (default 2)
AUTO_JOIN_MIN_MEMBERS=2

# Set true to auto-join whenever a member with an admin role enters any voice channel (ignores min member count)
AUTO_JOIN_ON_HOST_PRESENCE=false

# Comma-separated voice channel IDs the bot will never auto-join
IGNORED_CHANNEL_IDS=

# ── Recording behaviour ───────────────────────────────────
# Automatically stop a recording after this many minutes (default 180)
MAX_RECORDING_MINUTES=180

# Auto-leave voice channel after this many minutes of silence (default 5)
MAX_SILENCE_MINUTES=5

# Seconds to wait before a new session can start after one ends (default 60000 = 60s)
SESSION_COOLDOWN_MS=60000

# Delete local audio files after successful Discord upload (default true; set false to keep copies on disk)
DELETE_UPLOADED_RECORDINGS=true

# Send a DM to the session host(s) when a recording finishes (default true)
NOTIFY_HOST_DM=true

# Strip silences longer than 2 seconds from the merged audio file (default false)
TRIM_SILENCE=false

# Delete recordings older than this many days (default 30)
MAX_RECORDING_AGE_DAYS=30

# Warn and skip auto-join if free disk space is below this threshold (GB, default 1)
DISK_WARNING_GB=1

# ── Watchdog ──────────────────────────────────────────────
# How often (in hours) to post a heartbeat confirming the bot is alive (default 12, set 0 to disable)
WATCHDOG_INTERVAL_HOURS=12

# ── Auto-update webhook ───────────────────────────────────
# Set a secret to enable the webhook endpoint. Trigger with:
#   curl -X POST http://localhost:9000/update -H "x-webhook-secret: YOUR_SECRET"
WEBHOOK_SECRET=
WEBHOOK_PORT=9000
