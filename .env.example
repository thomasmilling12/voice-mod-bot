# ── Required ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here

# ── Channels (optional) ───────────────────────────────────
# Text channel ID where the bot posts "Recording started/stopped" messages
LOG_CHANNEL_ID=

# Text channel ID where crash alerts are posted
ALERT_CHANNEL_ID=

# Comma-separated voice channel IDs the bot will never auto-join
IGNORED_CHANNEL_IDS=

# ── Behavior (optional, all have defaults) ─────────────────
# Seconds to wait before auto-joining again after a session ends (default 60)
SESSION_COOLDOWN_MS=60000

# Delete recordings older than this many days (default 30)
MAX_RECORDING_AGE_DAYS=30

# Warn and skip join if free disk space is below this (GB, default 1)
DISK_WARNING_GB=1
