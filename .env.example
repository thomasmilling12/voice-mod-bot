# ── Required ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here

# ── Channels (optional) ───────────────────────────────────
# Text channel ID where the bot posts "Recording started/stopped" messages
LOG_CHANNEL_ID=

# Text channel ID where completed audio files are uploaded for download/playback
RECORDING_CHANNEL_ID=1496001557290946591

# Max audio file upload size in MB. Keep at 24 unless your server supports larger uploads.
DISCORD_UPLOAD_LIMIT_MB=24

# Text channel ID where crash alerts are posted
ALERT_CHANNEL_ID=

# Comma-separated Discord user IDs allowed to control the bot. Leave blank to allow server admins.
ADMIN_USER_IDS=

# Comma-separated Discord role IDs allowed to control the bot.
ADMIN_ROLE_IDS=850391095845584937,850391378559238235,990011447193006101,1055823929358430248

# Comma-separated voice channel IDs the bot will never auto-join
IGNORED_CHANNEL_IDS=

# ── Behavior (optional, all have defaults) ─────────────────
# Seconds to wait before auto-joining again after a session ends (default 60)
SESSION_COOLDOWN_MS=60000

# Delete recordings older than this many days (default 30)
MAX_RECORDING_AGE_DAYS=30

# Automatically stop a recording after this many minutes (default 180)
MAX_RECORDING_MINUTES=180

# Auto-leave voice channel after this many minutes of silence (default 5)
MAX_SILENCE_MINUTES=5

# Auto-join: minimum number of humans in a voice channel before the bot joins automatically (default 2)
AUTO_JOIN_MIN_MEMBERS=2

# How often (in hours) to post a heartbeat message to the recording channel confirming the bot is alive (default 12, set 0 to disable)
WATCHDOG_INTERVAL_HOURS=12

# Delete local audio files after successful Discord upload (default true)
DELETE_UPLOADED_RECORDINGS=true

# Send a DM to the session host(s) when a recording finishes (default true; set false to disable)
NOTIFY_HOST_DM=true

# Warn and skip join if free disk space is below this (GB, default 1)
DISK_WARNING_GB=1
